nextflow_workflow {

    name "Test Subworkflow CELLSAM_SEGMENT"
    script "../main.nf"
    workflow "CELLSAM_SEGMENT"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "subworkflows/cellsam_segment"
    tag "cellsamsegment"
    tag "cellmeasurement"


    test("cellsam_segment - tiff") {

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    false,  // run_backsub
                    false,  // run_mesmer
                    false,  // run_cellpose
                    true,   // run_cellsam
                    file("${projectDir}/tests/data/mesmer/test_data.tiff", checkIfExists: true), // tiff
                    "nuclear", // nuclear_channel
                    "membrane" // membrane_channels
                ])
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success},
                { assert snapshot(workflow.out).match()}
            )
        }
    }
}
