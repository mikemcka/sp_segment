
/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run WEHI-SODA-Hub/sp_segment -profile test_multisample,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test multisample profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    input                      = "${projectDir}/tests/cellpose_mesmer_multi_samplesheet.csv"
    patch_width_pixel          = 250
    patch_overlap_pixel        = 20
    remove_markers             = 'TRITC'
    skip_measurements          = false
}

env {
    CELLPOSE_LOCAL_MODELS_PATH = '/tmp/cellpose_models'
}
