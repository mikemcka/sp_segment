/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: 'EXTRACTMARKERS' {
        ext.args = {
            [
                params.containsKey('remove_markers') && params.remove_markers ?
                    params.remove_markers.split(',').collect { marker -> "--remove-marker ${marker}" }.join(' ') : null
            ].findAll { param -> param != null }.join(' ')
        }
    }

    withName: 'CELLMEASUREMENT' {
        ext.args = {
            [
                params.containsKey('enable_measurements') && params.enable_measurements ?
                    '--measurements' : '--no-measurements',
                params.containsKey('percentiles') && params.percentiles ?
                    "--percentiles=${params.percentiles}" : null,
                params.containsKey('erosion_steps') && params.erosion_steps ?
                    "--erosion-steps" : null,
                params.containsKey('expansion_steps') && params.expansion_steps ?
                    "--expansion-steps" : null,
                params.containsKey('environment_expansion') && params.environment_expansion ?
                    "--environment-expansion" : null,
                params.containsKey('pixel_size_microns') && params.pixel_size_microns ?
                    "--pixel-size-microns=${params.pixel_size_microns}" : null,
                params.containsKey('estimate_cell_boundary_dist') && params.estimate_cell_boundary_dist ?
                    "--estimate-cell-boundary-dist=${params.estimate_cell_boundary_dist}" : null,
                params.containsKey('neighbors') && params.neighbors ?
                    "--neighbors=${params.neighbors}" : null,
                params.containsKey('gzip_geojson') && params.gzip_geojson ?
                    '--gzip' : null,
                params.containsKey('dist_threshold') && params.dist_threshold != null ?
                    "--dist-threshold=${params.dist_threshold}" : null,
                params.containsKey('downsample_factor') && params.downsample_factor && params.downsample_factor != 1.0 ?
                    "--downsample-factor=${params.downsample_factor}" : null,
                params.containsKey('tile_size') && params.tile_size != null ?
                    "--tile-size=${params.tile_size}" : null,
                params.containsKey('tile_overlap') && params.tile_overlap != null ?
                    "--tile-overlap=${params.tile_overlap}" : null
            ].findAll { param -> param != null }.join(' ')
        }
    }

    withName: 'COMBINECHANNELS' {
        ext.args = {
            [
                params.containsKey('combine_method') && params.combine_method ?
                    "--combine-method ${params.combine_method}" : null,
                params.containsKey('pixel_size_microns') && params.pixel_size_microns ?
                    "--pixel-size-microns=${params.pixel_size_microns}" : null
            ].findAll { param -> param != null }.join(' ')
        }
    }

    withName: 'SOPA_SEGMENTATIONCELLPOSE' {
        ext.args = {
            [
                params.containsKey('cellpose_flow_threshold') && params.cellpose_flow_threshold != null ?
                    "--flow-threshold ${params.cellpose_flow_threshold}" : null,
                params.containsKey('cellpose_cellprob_threshold') && params.cellpose_cellprob_threshold != null ?
                    "--cellprob-threshold ${params.cellpose_cellprob_threshold}" : null,
                params.containsKey('cellpose_model_type') && params.cellpose_model_type != null ?
                    "--model-type ${params.cellpose_model_type}" : null,
                params.containsKey('cellpose_pretrained_model') && params.cellpose_pretrained_model != null ?
                    "--pretrained-model ${params.cellpose_pretrained_model}" : null
            ].findAll { param -> param != null }.join(' ')
        }
    }

    withName: 'MESMERSEGMENT' {
        ext.args = {
            [
                params.containsKey('combine_method') && params.combine_method ?
                    "--combine-method ${params.combine_method}" : '',
                params.containsKey('mesmer_segmentation_level') && params.mesmer_segmentation_level ?
                    "--segmentation-level ${params.mesmer_segmentation_level}" : '',
                params.containsKey('mesmer_maxima_threshold') && params.mesmer_maxima_threshold ?
                    "--maxima-threshold ${params.mesmer_maxima_threshold}" : '',
                params.containsKey('mesmer_interior_threshold') && params.mesmer_interior_threshold ?
                    "--interior-threshold ${params.mesmer_interior_threshold}" : '',
                params.containsKey('mesmer_maxima_smooth') && params.mesmer_maxima_smooth ?
                    "--maxima-smooth ${params.mesmer_maxima_smooth}" : '',
                params.containsKey('mesmer_min_nuclei_area') && params.mesmer_min_nuclei_area ?
                    "--min-nuclei-area ${params.mesmer_min_nuclei_area}" : '',
                params.containsKey('mesmer_remove_border_cells') ?
                    (params.mesmer_remove_border_cells ? '--remove-cells-touching-border' : '--no-remove-cells-touching-border') : '',
                params.containsKey('mesmer_pixel_expansion') && params.mesmer_pixel_expansion ?
                    "--pixel-expansion ${params.mesmer_pixel_expansion}" : '',
                params.containsKey('mesmer_padding') && params.mesmer_padding ?
                    "--padding ${params.mesmer_padding}" : '',
                params.containsKey('mesmer_transpose_mask') && params.mesmer_transpose_mask ?
                    '--force-transpose' : ''
            ].findAll { param -> param != null }.join(' ')
        }
    }

    withName: 'SMOOTHMASKS' {
        ext.args = {
            [
                params.containsKey('smooth_method') && params.smooth_method ?
                    "--method ${params.smooth_method}" : null,
                params.containsKey('smooth_kernel_size') && params.smooth_kernel_size != null ?
                    "--kernel-size ${params.smooth_kernel_size}" : null,
                params.containsKey('smooth_tolerance') && params.smooth_tolerance != null ?
                    "--tolerance ${params.smooth_tolerance}" : null,
                params.containsKey('smooth_min_area') && params.smooth_min_area != null ?
                    "--min-area ${params.smooth_min_area}" : null,
                params.containsKey('smooth_n_workers') && params.smooth_n_workers != null ?
                    "--n-workers ${params.smooth_n_workers}" : null,
                params.containsKey('smooth_chunksize') && params.smooth_chunksize != null ?
                    "--chunksize ${params.smooth_chunksize}" : null
            ].findAll { param -> param != null }.join(' ')
        }
    }

    withName: 'CELLSAMSEGMENT' {
        accelerator = 1
        clusterOptions = '--gres=gpu:1 --constraint=Ampere --partition=gpuq'
        containerOptions = {
            if (workflow.containerEngine == 'singularity' || workflow.containerEngine == 'apptainer') {
                return '--nv'
            } else if (workflow.containerEngine == 'docker') {
                return '--gpus all'
            } else {
                return ''
            }
        }
        ext.args = {
            [
                params.containsKey('cellsam_bbox_threshold') && params.cellsam_bbox_threshold != null ?
                    "--bbox-threshold ${params.cellsam_bbox_threshold}" : null,
                params.containsKey('cellsam_block_size') && params.cellsam_block_size != null ?
                    "--block-size ${params.cellsam_block_size}" : null,
                params.containsKey('cellsam_overlap') && params.cellsam_overlap != null ?
                    "--overlap ${params.cellsam_overlap}" : null,
                params.containsKey('cellsam_iou_depth') && params.cellsam_iou_depth != null ?
                    "--iou-depth ${params.cellsam_iou_depth}" : null,
                params.containsKey('cellsam_iou_threshold') && params.cellsam_iou_threshold != null ?
                    "--iou-threshold ${params.cellsam_iou_threshold}" : null,
                params.containsKey('cellsam_use_wsi') && params.cellsam_use_wsi ?
                    '--use-wsi' : null,
                params.containsKey('cellsam_gauge_cell_size') && params.cellsam_gauge_cell_size ?
                    '--gauge-cell-size' : null,
                params.containsKey('cellsam_low_contrast_enhancement') && params.cellsam_low_contrast_enhancement ?
                    '--low-contrast-enhancement' : null,
                params.containsKey('cellsam_model_path') && params.cellsam_model_path ?
                    "--model-path ${params.cellsam_model_path}" : null,
                params.containsKey('cellsam_min_area') && params.cellsam_min_area != null ?
                    "--min-area ${params.cellsam_min_area}" : null
            ].findAll { param -> param != null }.join(' ')
        }
    }

    withName: 'KRONOSEMBEDDINGS' {
        accelerator = 1
        queue = 'gpuq'
        clusterOptions = '--gres=gpu:1 --constraint=Ampere --partition=gpuq'
        containerOptions = '--nv'
        publishDir = [
            [
                path: { "${params.outdir}/cellmeasurement" },
                mode: params.publish_dir_mode,
                pattern: "*.geojson{,.gz}"
            ],
            [
                path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
                mode: params.publish_dir_mode,
                pattern: "*.{csv,txt}",
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        ]
        ext.args = {
            [
                params.containsKey('kronos_patch_size') && params.kronos_patch_size ?
                    "--patch-size ${params.kronos_patch_size}" : null,
                params.containsKey('kronos_batch_size') && params.kronos_batch_size ?
                    "--batch-size ${params.kronos_batch_size}" : null,
                params.containsKey('kronos_num_workers') && params.kronos_num_workers != null ?
                    "--num-workers ${params.kronos_num_workers}" : null,
                params.containsKey('kronos_max_value') && params.kronos_max_value ?
                    "--max-value ${params.kronos_max_value}" : null,
                params.containsKey('kronos_config_path') && params.kronos_config_path ?
                    "--config-path ${params.kronos_config_path}" : null,
                params.containsKey('kronos_marker_mapping') && params.kronos_marker_mapping ?
                    "--marker-mapping '${params.kronos_marker_mapping}'" : null,
                params.containsKey('kronos_distance_threshold') && params.kronos_distance_threshold != null ?
                    "--distance-threshold ${params.kronos_distance_threshold}" : null
            ].findAll { param -> param != null }.join(' ')
        }
    }

}
