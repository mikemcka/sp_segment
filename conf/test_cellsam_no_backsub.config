/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests with CellSAM (no background subtraction)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test CellSAM profile (no backsub)'
    config_profile_description = 'Minimal test dataset to check CellSAM pipeline without background subtraction'

    input                      = 'tests/cellsam_no_backsub_samplesheet.csv'

    // CellSAM specific test parameters (smaller for faster testing)
    cellsam_block_size         = 256
    cellsam_overlap            = 32
    cellsam_iou_depth          = 28  // Must be <= overlap
    cellsam_bbox_threshold     = 0.4
    cellsam_use_wsi            = true
}
