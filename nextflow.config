/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    WEHI-SODA-Hub/sp_segment Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments
----------------------------------------------------------------------------------------
*/

// Global default params, used in configs
params {

    // Input options
    input                        = null

    // Boilerplate options
    outdir                       = null
    publish_dir_mode             = 'copy'
    email                        = null
    email_on_fail                = null
    plaintext_email              = false
    monochrome_logs              = false
    hook_url                     = null
    help                         = false
    help_full                    = false
    show_hidden                  = false
    version                      = false
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'

    // background subtraction options
    remove_markers               = 'TRITC,Cy5'

    // cell processing options
    use_whole_cell_only          = false

    // combine channels options
    combine_method               = 'max'

    // sopa segmentation options
    technology                   = 'ome_tif'
    patch_width_pixel            = 3000
    patch_overlap_pixel          = 250

    // cellpose options
    cellpose_diameter            = 30
    cellpose_min_area            = 200
    cellpose_flow_threshold      = 0.4
    cellpose_cellprob_threshold  = 0.0
    cellpose_model_type          = 'cyto3'
    cellpose_pretrained_model    = null

    // mesmer options
    mesmer_segmentation_level    = null
    mesmer_maxima_threshold      = 0.1
    mesmer_interior_threshold    = 0.3
    mesmer_maxima_smooth         = 0
    mesmer_min_nuclei_area       = 40
    mesmer_remove_border_cells   = true
    mesmer_pixel_expansion       = 3
    mesmer_padding               = 0
    mesmer_transpose_mask        = false

    // deepcell model cache (set to a shared scratch path; username is resolved at runtime)
    deepcell_cache_dir           = null

    // cellsam options
    cellsam_bbox_threshold       = 0.4
    cellsam_block_size           = 600
    cellsam_overlap              = 250
    cellsam_iou_depth            = 250
    cellsam_iou_threshold        = 0.5
    cellsam_use_wsi              = true
    cellsam_gauge_cell_size      = false
    cellsam_low_contrast_enhancement = false
    cellsam_model_path           = null
    cellsam_min_area             = 0

    // kronos embedding options
    enable_kronos                = false
    kronos_model_path            = null
    kronos_config_path           = null
    kronos_marker_metadata       = null
    kronos_patch_size            = 64
    kronos_batch_size            = 32
    kronos_num_workers           = 4
    kronos_max_value             = 65535
    kronos_marker_mapping        = null
    kronos_distance_threshold    = 5.0

    // mask smoothing options
    smooth_masks                 = false
    smooth_method                = 'morphological'
    smooth_kernel_size           = 2
    smooth_tolerance             = 1
    smooth_min_area              = 0
    smooth_n_workers             = 8
    smooth_chunksize             = 200

    // measurement options
    enable_measurements          = true
    percentiles                  = '70,80,90,95,99'
    // Erosion bins: 5 equal-area rings eroding inward from cell/nucleus boundary
    erosion_steps                = true
    // Expansion bins: 5 equal-area rings within 20 µm outward from cell boundary
    expansion_steps              = true
    // Environment expansion: 20 µm zone around each cell, computed automatically from pixel_size_microns
    environment_expansion        = true
    pixel_size_microns           = 0.28
    estimate_cell_boundary_dist  = 3
    neighbors                    = 5
    gzip_geojson                 = true
    // Distance threshold (pixels) for matching nuclear to whole-cell centroids
    dist_threshold               = 10.0
    // Downsample factor applied to image and masks before measurement (1 = no downsampling)
    downsample_factor            = 1.0

    // report options
    generate_report              = false

    // Config options
    config_profile_name          = null
    config_profile_description   = null

    custom_config_version        = 'master'
    custom_config_base           = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
    config_profile_contact       = null
    config_profile_url           = null

    // Schema validation default options
    validate_params              = true

    // Timestamp
    trace_timestamp = {
        return new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
    }.call()
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        conda.channels          = ['conda-forge', 'bioconda']
        apptainer.enabled       = false
    }
    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    arm {
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    gitpod {
        executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 8.GB
    }

    // Test profiles
    // Cellpose
    test {
        includeConfig 'conf/test.config'
    }
    // Cellpose (no background subtraction)
    test_no_backsub {
        includeConfig 'conf/test_no_backsub.config'
    }
    // Multisample test
    test_multisample {
        includeConfig 'conf/test_multisample.config'
    }
    test_mesmer {
        includeConfig 'conf/test_mesmer.config'
    }
    test_mesmer_no_backsub {
        includeConfig 'conf/test_mesmer_no_backsub.config'
    }
    test_cellsam  {
        includeConfig 'conf/test_cellsam.config'
    }
    test_cellsam_no_backsub {
        includeConfig 'conf/test_cellsam_no_backsub.config'
    }

    // For images 150GB and below — targets sml nodes (28 cores, 113GB)
    small {
        process {
            executor = 'slurm'
            queue = 'regular'

            withLabel: 'process_medium' {
                cpus   = { 1 }
                memory = { 24.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_high' {
                cpus   = { 1 }
                memory = { 36.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_single' {
                cpus   = { 1 }
                memory = { 36.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_multi' {
                cpus   = { 14 }                        // half of sml 28 physical cores
                memory = { 36.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_gpu' {
                cpus   = { 12 }                        // half of A10 24 cores
                memory = { 48.GB * task.attempt }      // A10: 238GB (48*2=96GB)
                time   = { 48.h }
                queue  = 'gpuq'
                clusterOptions = '--gres=gpu:1 --constraint=Ampere'
                containerOptions = {
                    if (workflow.containerEngine == 'singularity' || workflow.containerEngine == 'apptainer') {
                        return '--nv'
                    } else if (workflow.containerEngine == 'docker') {
                        return '--gpus all'
                    } else {
                        return ''
                    }
                }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }
    // For images 300GB and below — targets med nodes (28 cores, 491GB) / il nodes (48 cores, 491GB)
    medium {
        process {
            executor = 'slurm'
            queue = 'regular'

            withLabel: 'process_medium' {
                cpus   = { 1 }
                memory = { 48.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_high' {
                cpus   = { 1 }
                memory = { 120.GB * task.attempt }     // med/il: 491GB (120*2=240GB)
                time   = { 48.h }
            }
            withLabel: 'process_single' {
                cpus   = { 1 }
                memory = { 120.GB * task.attempt }     // med/il: 491GB (120*2=240GB)
                time   = { 48.h }
            }
            withLabel: 'process_multi' {
                cpus   = { 24 }                        // fits med (28) and il (48) cores
                memory = { 120.GB * task.attempt }     // med/il: 491GB (120*2=240GB)
                time   = { 48.h }
            }
            withLabel: 'process_gpu' {
                cpus   = { 16 }                        // 1/3 of A30/A100 48 cores
                memory = { 120.GB * task.attempt }     // A30: 490GB (120*2=240GB)
                time   = { 48.h }
                queue  = 'gpuq'
                clusterOptions = '--gres=gpu:1 --constraint=Ampere'
                containerOptions = {
                    if (workflow.containerEngine == 'singularity' || workflow.containerEngine == 'apptainer') {
                        return '--nv'
                    } else if (workflow.containerEngine == 'docker') {
                        return '--gpus all'
                    } else {
                        return ''
                    }
                }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }
    // For images 600GB and below — targets lrg nodes (64 cores, 1498GB)
    large {
        process {
            executor = 'slurm'
            queue = 'regular'

            withLabel: 'process_medium' {
                cpus   = { 1 }
                memory = { 192.GB * task.attempt }
                time   = { 48.h }
            }
            withLabel: 'process_high' {
                cpus   = { 1 }
                memory = { 450.GB * task.attempt }     // lrg: 1498GB (450*2=900GB)
                time   = { 48.h }
            }
            withLabel: 'process_single' {
                cpus   = { 1 }
                memory = { 450.GB * task.attempt }     // lrg: 1498GB (450*2=900GB)
                time   = { 48.h }
            }
            withLabel: 'process_multi' {
                cpus   = { 48 }                        // 3/4 of lrg 64 physical cores
                memory = { 450.GB * task.attempt }     // lrg: 1498GB (450*2=900GB)
                time   = { 48.h }
            }
            withLabel: 'process_gpu' {
                cpus   = { 24 }                        // half of A100 48 cores
                memory = { 450.GB * task.attempt }     // A100: 994GB (450*2=900GB)
                time   = { 48.h }
                queue  = 'gpuq'
                clusterOptions = '--gres=gpu:1 --constraint=Ampere'
                containerOptions = {
                    if (workflow.containerEngine == 'singularity' || workflow.containerEngine == 'apptainer') {
                        return '--nv'
                    } else if (workflow.containerEngine == 'docker') {
                        return '--gpus all'
                    } else {
                        return ''
                    }
                }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }
}

// Load nf-core custom profiles from different Institutions
includeConfig !System.getenv('NXF_OFFLINE') && params.custom_config_base ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

// Load WEHI-SODA-Hub/sp_segment custom profiles from different institutions.
// includeConfig !System.getenv('NXF_OFFLINE') && params.custom_config_base ? "${params.custom_config_base}/pipeline/sp_segment.config" : "/dev/null"

// Set default registry for Apptainer, Docker, Podman, Charliecloud and Singularity independent of -profile
// Will not be used unless Apptainer / Docker / Podman / Charliecloud / Singularity are enabled
// Set to your registry if you have a mirror of containers
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'

// Export these variables to prevent local Python/R libraries from conflicting with those in the container
// The JULIA depot path has been adjusted to a fixed path `/usr/local/share/julia` that needs to be used for packages in the container.
// See https://apeltzer.github.io/post/03-julia-lang-nextflow/ for details on that. Once we have a common agreement on where to keep Julia packages, this is adjustable.

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

// Set bash options
process.shell = [
    "bash",
    "-C",         // No clobber - prevent output redirection from overwriting files.
    "-e",         // Exit if a tool returns a non-zero status/exit code
    "-u",         // Treat unset variables and parameters as an error
    "-o",         // Returns the status of the last command to exit..
    "pipefail"    //   ..with a non-zero status or zero if all successfully execute
]

// Disable process selector warnings by default. Use debug profile to enable warnings.
nextflow.enable.configProcessNamesValidation = false

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${params.trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${params.trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${params.trace_timestamp}.html"
}

manifest {
    name            = 'WEHI-SODA-Hub/sp_segment'
    author          = """WEHI SODA Hub"""
    homePage        = 'https://github.com/WEHI-SODA-Hub/sp_segment'
    description     = """Cell segmentation and downstream analysis pipeline for the COMET, MIBI, and OPAL spatial platforms"""
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.2'
    version         = '0.3.1'
    doi             = ''
}

// Nextflow plugins
plugins {
    id 'nf-schema@2.1.1' // Validation of pipeline parameters and creation of an input channel from a sample sheet
}


validation {
    defaultIgnoreParams = ["genomes"]
    ignoreParams = ['trace_timestamp']
    help {
        enabled = true
        command = "nextflow run WEHI-SODA-Hub/sp_segment -profile <docker/singularity/.../institute> --input samplesheet.csv --outdir <OUTDIR>"
        fullParameter = "help_full"
        showHiddenParameter = "show_hidden"
        beforeText = """
-\033[2m----------------------------------------------------\033[0m-
                                        \033[0;32m,--.\033[0;30m/\033[0;32m,-.\033[0m
\033[0;34m        ___     __   __   __   ___     \033[0;32m/,-._.--~\'\033[0m
\033[0;34m  |\\ | |__  __ /  ` /  \\ |__) |__         \033[0;33m}  {\033[0m
\033[0;34m  | \\| |       \\__, \\__/ |  \\ |___     \033[0;32m\\`-._,-`-,\033[0m
                                        \033[0;32m`._,._,\'\033[0m
\033[0;35m  WEHI-SODA-Hub/sp_segment v0.3.1\033[0m
-\033[2m----------------------------------------------------\033[0m-
"""
        afterText = """
* The nf-core framework
    https://doi.org/10.1038/s41587-020-0439-x

* Software dependencies
    https://github.com/WEHI-SODA-Hub/sp_segment/blob/master/CITATIONS.md
"""
    }
    summary {
        beforeText = """
-\033[2m----------------------------------------------------\033[0m-
                                        \033[0;32m,--.\033[0;30m/\033[0;32m,-.\033[0m
\033[0;34m        ___     __   __   __   ___     \033[0;32m/,-._.--~\'\033[0m
\033[0;34m  |\\ | |__  __ /  ` /  \\ |__) |__         \033[0;33m}  {\033[0m
\033[0;34m  | \\| |       \\__, \\__/ |  \\ |___     \033[0;32m\\`-._,-`-,\033[0m
                                        \033[0;32m`._,._,\'\033[0m
\033[0;35m  WEHI-SODA-Hub/sp_segment v0.3.1\033[0m
-\033[2m----------------------------------------------------\033[0m-
"""
        afterText = """
* The nf-core framework
    https://doi.org/10.1038/s41587-020-0439-x

* Software dependencies
    https://github.com/WEHI-SODA-Hub/sp_segment/blob/master/CITATIONS.md
"""
    }
}

// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'
